# Database
DATABASE_URL="postgresql://username:password@localhost:5432/lioncore_platform?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="noreply@lioncore.com"
FROM_NAME="LionCore Platform"

# reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your-recaptcha-site-key"
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Feature Flags (can also be managed via database)
ENABLE_PHONE_LOGIN="false"
ENABLE_MULTI_CANDIDATE="false"
ENABLE_DEBATE="false"
ENABLE_DONATIONS="false"

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# YouTube
CAMPAIGN_VIDEO_URL="https://www.youtube.com/embed/your-video-id"

# Election Date (for countdown)
ELECTION_DATE="2024-09-21T00:00:00Z"
